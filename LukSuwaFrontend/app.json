{
  "expo": {
    "name": "LukSuwa",
    "slug": "luksuwa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/luksuwa-icon.png",
    "scheme": "luksuwafrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": ""
      },
      "infoPlist": {
        "NSCameraUsageDescription": "LukSuwa needs camera access for video calls with doctors",
        "NSMicrophoneUsageDescription": "LukSuwa needs microphone access for voice and video calls with doctors",
        "NSLocationWhenInUseUsageDescription": "LukSuwa needs your location to show nearby pharmacies."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/luksuwa-adaptive-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dilanrajitha.LukSuwaFrontend",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/luksuwa-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LukSuwa to access your camera for video calls with doctors",
          "microphonePermission": "Allow LukSuwa to access your microphone for voice and video calls with doctors",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "433b60ed-7cdd-4850-81f6-1b902a13868c"
      }
    }
  }
}
